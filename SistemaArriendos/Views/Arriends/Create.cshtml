@model SistemaArriendos.Models.Arriendo

@{
    ViewData["Title"] = "Crear Arriendo";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-10 mx-auto">
            <div class="card shadow-lg">
                <div class="card-header bg-success text-white">
                    <h4 class="mb-0"><i class="bi bi-plus-circle"></i> Nuevo Arriendo</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="ClienteId" class="form-label fw-bold">Cliente</label>
                                <select asp-for="ClienteId" class="form-select" asp-items="ViewBag.ClienteId">
                                    <option selected disabled>-- Seleccione un cliente --</option>
                                </select>
                                <span asp-validation-for="ClienteId" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="VehiculoId" class="form-label fw-bold">Vehículo (Disponibles)</label>
                                <select asp-for="VehiculoId" class="form-select" asp-items="ViewBag.VehiculoId">
                                    <option selected disabled>-- Seleccione un vehículo --</option>
                                </select>
                                <span asp-validation-for="VehiculoId" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="FechaInicio" class="form-label fw-bold">Fecha Inicio</label>
                                <input asp-for="FechaInicio" class="form-control" type="date" />
                                <span asp-validation-for="FechaInicio" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="FechaFin" class="form-label fw-bold">Fecha Fin</label>
                                <input asp-for="FechaFin" class="form-control" type="date" />
                                <span asp-validation-for="FechaFin" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="PrecioDiario" class="form-label fw-bold">Precio Diario ($)</label>
                                <input asp-for="PrecioDiario" class="form-control" type="number" step="0.01" min="0" />
                                <span asp-validation-for="PrecioDiario" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="PrecioTotal" class="form-label fw-bold">Precio Total ($)</label>
                                <input asp-for="PrecioTotal" class="form-control" type="number" step="0.01" min="0" disabled />
                                <small class="text-muted">Se calcula automáticamente</small>
                            </div>
                        </div>

                        <hr />

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Cancelar
                            </a>
                            <button type="submit" class="btn btn-success">
                                <i class="bi bi-check-circle"></i> Crear Arriendo
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
