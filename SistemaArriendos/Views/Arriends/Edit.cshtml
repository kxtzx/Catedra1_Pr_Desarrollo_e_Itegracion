@model SistemaArriendos.Models.Arriendo

@{
    ViewData["Title"] = "Editar Arriendo";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-10 mx-auto">
            <div class="card shadow-lg">
                <div class="card-header bg-warning text-dark">
                    <h4 class="mb-0"><i class="bi bi-pencil-square"></i> Editar Arriendo</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <input type="hidden" asp-for="Id" />

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="ClienteId" class="form-label fw-bold">Cliente</label>
                                <select asp-for="ClienteId" class="form-select" asp-items="ViewBag.ClienteId"></select>
                                <span asp-validation-for="ClienteId" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="VehiculoId" class="form-label fw-bold">Vehículo</label>
                                <select asp-for="VehiculoId" class="form-select" asp-items="ViewBag.VehiculoId"></select>
                                <span asp-validation-for="VehiculoId" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="FechaInicio" class="form-label fw-bold">Fecha Inicio</label>
                                <input asp-for="FechaInicio" class="form-control" type="date" />
                                <span asp-validation-for="FechaInicio" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="FechaFin" class="form-label fw-bold">Fecha Fin</label>
                                <input asp-for="FechaFin" class="form-control" type="date" />
                                <span asp-validation-for="FechaFin" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="PrecioDiario" class="form-label fw-bold">Precio Diario ($)</label>
                                <input asp-for="PrecioDiario" class="form-control" type="number" step="0.01" min="0" />
                                <span asp-validation-for="PrecioDiario" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="PrecioTotal" class="form-label fw-bold">Precio Total ($)</label>
                                <input asp-for="PrecioTotal" class="form-control" type="number" step="0.01" min="0" readonly />
                                <span asp-validation-for="PrecioTotal" class="text-danger small"></span>
                            </div>
                        </div>

                        <hr />

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Cancelar
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-circle"></i> Guardar Cambios
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        (function () {
            const fechaInicio = document.getElementById('FechaInicio');
            const fechaFin = document.getElementById('FechaFin');
            const precioDiario = document.getElementById('PrecioDiario');
            const precioTotal = document.getElementById('PrecioTotal');

            function calcularTotal() {
                if (!fechaInicio || !fechaFin || !precioDiario || !precioTotal) return;

                const inicio = fechaInicio.value ? new Date(fechaInicio.value + 'T00:00:00') : null;
                const fin = fechaFin.value ? new Date(fechaFin.value + 'T00:00:00') : null;
                const diario = parseFloat(precioDiario.value) || 0;

                if (!inicio || !fin || isNaN(inicio.getTime()) || isNaN(fin.getTime())) {
                    precioTotal.value = '';
                    return;
                }

                const diffMs = fin.getTime() - inicio.getTime();
                const diffDias = Math.ceil(diffMs / (1000 * 60 * 60 * 24));

                if (diffDias < 0) {
                    precioTotal.value = '';
                    return;
                }

                const dias = diffDias === 0 ? 1 : diffDias;
                precioTotal.value = (dias * diario).toFixed(2);
            }

            ['input', 'change'].forEach(eventName => {
                fechaInicio.addEventListener(eventName, calcularTotal);
                fechaFin.addEventListener(eventName, calcularTotal);
                precioDiario.addEventListener(eventName, calcularTotal);
            });

            calcularTotal();
        })();
    </script>
}
