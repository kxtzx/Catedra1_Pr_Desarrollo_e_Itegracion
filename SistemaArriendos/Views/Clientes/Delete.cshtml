@model SistemaArriendos.Models.Cliente

@{
    ViewData["Title"] = "Eliminar Cliente";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-6 mx-auto">
            <div class="card border-danger shadow-lg">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0"><i class="bi bi-exclamation-triangle"></i> Confirmar Eliminación</h4>
                </div>
                <div class="card-body">
                    <p class="text-muted">¿Está seguro que desea eliminar este cliente?</p>
                    <p class="text-danger fw-bold">Esta acción no se puede deshacer.</p>

                    <div class="alert alert-warning" role="alert">
                        <strong>Información del cliente a eliminar:</strong>
                        <dl class="row mt-3">
                            <dt class="col-md-4"><i class="bi bi-hash"></i> RUT:</dt>
                            <dd class="col-md-8"><span class="badge bg-info">@Model.Rut</span></dd>

                            <dt class="col-md-4"><i class="bi bi-person"></i> Nombre:</dt>
                            <dd class="col-md-8"><strong>@Model.Nombre</strong></dd>

                            <dt class="col-md-4"><i class="bi bi-geo-alt"></i> Dirección:</dt>
                            <dd class="col-md-8">@Model.Direccion</dd>
                        </dl>
                    </div>

                    <form asp-action="Delete" method="post" class="mt-4">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Cancelar
                            </a>
                            <button type="submit" class="btn btn-danger">
                                <i class="bi bi-trash"></i> Eliminar Cliente
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
