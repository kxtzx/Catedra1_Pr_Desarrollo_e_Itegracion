@model SistemaArriendos.Models.Cliente

@{
    ViewData["Title"] = "Detalles del Cliente";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card shadow-lg">
                <div class="card-header bg-info text-white">
                    <h4 class="mb-0"><i class="bi bi-person-circle"></i> Detalles del Cliente</h4>
                </div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-md-3"><i class="bi bi-hash"></i> RUT:</dt>
                        <dd class="col-md-9">
                            <span class="badge bg-info fs-6">@Model.Rut</span>
                        </dd>

                        <dt class="col-md-3"><i class="bi bi-person"></i> Nombre:</dt>
                        <dd class="col-md-9">
                            <strong class="fs-5">@Model.Nombre</strong>
                        </dd>

                        <dt class="col-md-3"><i class="bi bi-geo-alt"></i> Dirección:</dt>
                        <dd class="col-md-9">
                            <p>@Model.Direccion</p>
                        </dd>
                    </dl>

                    <hr />

                    <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-arrow-left"></i> Volver
                        </a>
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
                            <i class="bi bi-pencil"></i> Editar
                        </a>
                        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">
                            <i class="bi bi-trash"></i> Eliminar
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
