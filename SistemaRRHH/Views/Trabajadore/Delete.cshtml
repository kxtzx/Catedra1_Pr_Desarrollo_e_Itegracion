@model SistemaRRHH.Models.Trabajadore
@using System.Globalization

@{
    ViewData["Title"] = "Eliminar Trabajador";
    var cultura = new CultureInfo("es-CL");
}

<div class="container-fluid mt-5">
    <div class="row mb-4">
        <div class="col-lg-8">
            <h1 class="display-5 fw-bold mb-2">Eliminar Trabajador</h1>
            <p class="text-muted fs-5 mb-0">Esta acción es irreversible. Verifica los datos antes de continuar.</p>
        </div>
    </div>

    <div class="alert alert-danger border-0 shadow-sm" role="alert">
        <strong>Atención:</strong> Estás a punto de eliminar el registro de <strong>@Model.Nombre</strong>.
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-dark text-white">
            <strong><i class="bi bi-person-x-fill me-2"></i>@Model.Nombre</strong>
        </div>
        <div class="card-body">
            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <div class="p-3 bg-light rounded-3 h-100">
                        <div class="text-muted small mb-1">RUT</div>
                        <span class="badge bg-dark px-3 py-2">@Model.Rut</span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="p-3 bg-light rounded-3 h-100">
                        <div class="text-muted small mb-1">Nombre</div>
                        <div class="fw-semibold fs-5">@Model.Nombre</div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="p-3 bg-light rounded-3 h-100">
                        <div class="text-muted small mb-1">Sueldo Base</div>
                        <div class="fw-semibold fs-5 text-success">@Model.SueldoBase.ToString("C2", cultura)</div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="p-3 bg-light rounded-3 h-100">
                        <div class="text-muted small mb-1">Valor Hora</div>
                        <div class="fw-semibold fs-5 text-primary">@Model.ValorHora.ToString("C2", cultura)</div>
                    </div>
                </div>
            </div>

            <form asp-action="Delete" class="d-flex gap-2 justify-content-end">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger">
                    <i class="bi bi-trash-fill me-2"></i>Eliminar
                </button>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left me-2"></i>Cancelar
                </a>
            </form>
        </div>
    </div>
</div>
