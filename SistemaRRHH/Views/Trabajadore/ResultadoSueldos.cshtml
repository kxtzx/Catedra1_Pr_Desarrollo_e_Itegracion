@model IEnumerable<SistemaRRHH.ViewModels.ResultadoSueldoViewModel>
@using System.Globalization

@{
    ViewData["Title"] = "Resultado Sueldos";
    var cultura = new CultureInfo("es-CL");
}

<div class="container-fluid mt-5">
    <div class="row align-items-center mb-4 g-3">
        <div class="col-lg-8 col-md-7">
            <h1 class="display-4 fw-bold mb-2">Sueldos Calculados Exitosamente</h1>
            <p class="text-muted fs-5 mb-0">Sube un archivo JSON con horas trabajadas para recalcular los sueldos automáticamente.</p>
        </div>
        <div class="col-lg-4 col-md-5 text-md-end">
            <a asp-action="Index" class="btn btn-secondary btn-lg shadow-sm px-4">
                <i class="bi bi-arrow-left-circle me-2"></i>Volver al listado
            </a>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <form asp-action="CargarJson" asp-controller="Trabajadore" method="post" enctype="multipart/form-data" class="row g-3 align-items-end">
                @Html.AntiForgeryToken()
                <div class="col-md-9">
                    <label for="archivo" class="form-label fw-semibold">Archivo JSON</label>
                    <input type="file" class="form-control" id="archivo" name="archivo" accept="application/json" />
                    <div class="form-text">Formato esperado: [{"rut":"77777777-7","horas":45},{"rut":"88888888-8","horas":38}]</div>
                </div>
                <div class="col-md-3 d-grid">
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="bi bi-upload me-2"></i>Calcular Sueldos
                    </button>
                </div>
            </form>
        </div>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="card shadow-sm border-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th scope="col">RUT</th>
                            <th scope="col">Nombre</th>
                            <th scope="col">Horas Trabajadas</th>
                            <th scope="col">Sueldo Base</th>
                            <th scope="col">Valor Hora</th>
                            <th scope="col">Sueldo Final</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td><span class="badge bg-dark px-3 py-2">@item.Rut</span></td>
                                <td><strong>@item.Nombre</strong></td>
                                <td>@item.HorasTrabajadas.ToString("N2", cultura)</td>
                                <td>@item.SueldoBase.ToString("C2", cultura)</td>
                                <td>@item.ValorHora.ToString("C2", cultura)</td>
                                <td><strong class="text-success">@item.SueldoFinal.ToString("C2", cultura)</strong></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info text-center py-5 border-0 shadow-sm" role="alert">
            <i class="bi bi-inbox" style="font-size: 3rem; display:block; margin-bottom: 1rem;"></i>
            <h5 class="fw-bold">La tabla está vacía</h5>
            <p class="mb-0">Sube un archivo JSON para calcular y mostrar los sueldos.</p>
        </div>
    }
</div>