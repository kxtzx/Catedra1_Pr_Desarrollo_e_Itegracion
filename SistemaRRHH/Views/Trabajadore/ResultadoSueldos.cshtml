@model IEnumerable<SistemaRRHH.Controllers.ResultadoSueldoViewModel>

@{
    ViewData["Title"] = "Cálculo de Sueldos del Mes";
}

<div class="container mt-4">
    <h2><i class="bi bi-calculator"></i> Sueldos Calculados Exitosamente</h2>
    <p class="text-muted">A continuación se detalla el sueldo final de los mecánicos según las horas procesadas en el archivo JSON.</p>

    <table class="table table-striped table-bordered mt-3">
        <thead class="table-dark">
            <tr>
                <th>RUT Mecánico</th>
                <th>Nombre Completo</th>
                <th>Sueldo Final (Base + Horas)</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Rut</td>
                    <td>@item.Nombre</td>
                    <td class="text-end fw-bold">$ @item.SueldoFinal.ToString("N0")</td>
                </tr>
            }
        </tbody>
    </table>

    <div class="mt-4">
        <a asp-action="Index" class="btn btn-secondary">Volver al Listado de Trabajadores</a>
    </div>
</div>