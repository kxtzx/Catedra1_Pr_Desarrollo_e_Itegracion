@{
    ViewData["Title"] = "Sistema de Mantenimiento";
}

<div class="container mt-5">
    <div class="row mb-5">
        <div class="col-12">
            <h1 class="display-4 text-center mb-2">Sistema de Mantenimiento</h1>
            <p class="text-center text-muted mb-5">Registro y control de vehículos y mantenciones</p>
        </div>
    </div>

    <div class="row g-4">
        <!-- Vehículos -->
        <div class="col-md-6 col-lg-4">
            <div class="card h-100 shadow-sm border-0 hover-card">
                <div class="card-body text-center">
                    <h2 class="mb-3"></h2>
                    <h5 class="card-title">Vehículos</h5>
                    <p class="card-text text-muted">Registro de vehículos con patente, marca, modelo, tipo, kilometraje y estado</p>
                    <a href="/Vehiculos" class="btn btn-primary btn-sm w-100">Acceder</a>
                </div>
            </div>
        </div>

        <!-- Mantenciones -->
        <div class="col-md-6 col-lg-4">
            <div class="card h-100 shadow-sm border-0 hover-card">
                <div class="card-body text-center">
                    <h2 class="mb-3"></h2>
                    <h5 class="card-title">Mantenciones</h5>
                    <p class="card-text text-muted">Registra mantenciones realizadas a los vehículos con fecha, mecánico y horas</p>
                    <a href="/Mantenciones" class="btn btn-primary btn-sm w-100">Acceder</a>
                </div>
            </div>
        </div>

        <!-- Información -->
        <div class="col-md-6 col-lg-4">
            <div class="card h-100 shadow-sm border-0 hover-card">
                <div class="card-body text-center">
                    <h2 class="mb-3"></h2>
                    <h5 class="card-title">Información</h5>
                    <p class="card-text text-muted">Detalles del sistema y funcionalidades disponibles</p>
                    <a href="/Home/Privacy" class="btn btn-primary btn-sm w-100">Acceder</a>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-5">
        <div class="col-12">
            <div class="alert alert-info">
                <strong>Nota:</strong> Sistema compartido con Arriendos (comparten la misma base de datos). Genera archivo de horas para RRHH
            </div>
        </div>
    </div>
</div>

<style>
    .hover-card {
        transition: transform 0.2s, box-shadow 0.2s;
    }
    
    .hover-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
    }

    .display-4 {
        font-weight: 700;
        color: #2c3e50;
    }
</style>
