@model IEnumerable<SistemaMantencion.Models.Vehiculo>

@{
    ViewData["Title"] = "Vehículos";
}

<div class="container-fluid mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1 class="display-4">Gestión de Vehículos</h1>
            <p class="text-muted">Administra el inventario de todos los vehículos</p>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="Create" class="btn btn-primary btn-lg">
                <i class="bi bi-plus-circle"></i> Nuevo Vehículo
            </a>
        </div>
    </div>

    @if (Model.Any())
    {
        <div class="card shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover table-striped mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th scope="col">Código</th>
                            <th scope="col">Patente</th>
                            <th scope="col">Marca/Modelo</th>
                            <th scope="col">Tipo</th>
                            <th scope="col">Km</th>
                            <th scope="col">Estado</th>
                            <th scope="col">Precio/Día</th>
                            <th scope="col" class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var estadoBadge = item.Estado == "Disponible" ? "bg-success" : 
                                             item.Estado == "Arrendado" ? "bg-warning" : 
                                             item.Estado == "Mantenimiento" ? "bg-info" : "bg-secondary";
                            <tr>
                                <td><span class="badge bg-dark">@item.Codigo</span></td>
                                <td><strong>@item.Patente</strong></td>
                                <td>@item.Marca @item.Modelo</td>
                                <td>@item.Tipo</td>
                                <td>@item.Kilometraje km</td>
                                <td><span class="badge @estadoBadge">@item.Estado</span></td>
                                <td>$ @item.PrecioArriendoDiario.ToString("N2")</td>
                                <td class="text-center">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info" title="Ver detalles">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning" title="Editar">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger" title="Eliminar">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info text-center py-5" role="alert">
            <i class="bi bi-inbox" style="font-size: 3rem; display: block; margin-bottom: 1rem;"></i>
            <h5>No hay vehículos registrados</h5>
            <p class="mb-0">Haz clic en "Nuevo Vehículo" para crear el primer registro</p>
        </div>
    }
</div>
