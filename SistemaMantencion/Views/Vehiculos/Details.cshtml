@model SistemaMantencion.Models.Vehiculo

@{
    ViewData["Title"] = "Detalles del Vehículo";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-10 mx-auto">
            <div class="card shadow-lg">
                <div class="card-header bg-info text-white">
                    <h4 class="mb-0"><i class="bi bi-info-circle"></i> Detalles del Vehículo</h4>
                </div>
                <div class="card-body">
                    <div class="row mb-4">
                        <div class="col-md-6 mb-3">
                            <h6 class="text-muted text-uppercase small fw-bold">Código</h6>
                            <p class="h5"><span class="badge bg-dark">@Model.Codigo</span></p>
                        </div>
                        <div class="col-md-6 mb-3">
                            <h6 class="text-muted text-uppercase small fw-bold">Patente</h6>
                            <p class="h4 fw-bold">@Model.Patente</p>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-6 mb-3">
                            <h6 class="text-muted text-uppercase small fw-bold">Marca</h6>
                            <p class="h5">@Model.Marca</p>
                        </div>
                        <div class="col-md-6 mb-3">
                            <h6 class="text-muted text-uppercase small fw-bold">Modelo</h6>
                            <p class="h5">@Model.Modelo</p>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-4 mb-3">
                            <h6 class="text-muted text-uppercase small fw-bold"><i class="bi bi-diagram-3"></i> Tipo</h6>
                            <p class="h5">@Model.Tipo</p>
                        </div>
                        <div class="col-md-4 mb-3">
                            <h6 class="text-muted text-uppercase small fw-bold"><i class="bi bi-speedometer"></i> Kilometraje</h6>
                            <p class="h5">@Model.Kilometraje km</p>
                        </div>
                        <div class="col-md-4 mb-3">
                            <h6 class="text-muted text-uppercase small fw-bold"><i class="bi bi-currency-dollar"></i> Precio Diario</h6>
                            <p class="h5 text-success fw-bold">$ @Model.PrecioArriendoDiario.ToString("N2")</p>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-12 mb-3">
                            <h6 class="text-muted text-uppercase small fw-bold"><i class="bi bi-flag"></i> Estado</h6>
                            @{
                                var estadoBadge = Model.Estado == "Disponible" ? "bg-success" :
                                                 Model.Estado == "Arrendado" ? "bg-warning" :
                                                 Model.Estado == "Mantenimiento" ? "bg-info" : "bg-secondary";
                            }
                            <p><span class="badge @estadoBadge" style="font-size: 0.95rem; padding: 0.6rem 1rem;">@Model.Estado</span></p>
                        </div>
                    </div>

                    <hr />

                    <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-arrow-left"></i> Volver al Listado
                        </a>
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning text-dark fw-bold">
                            <i class="bi bi-pencil"></i> Editar
                        </a>
                        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">
                            <i class="bi bi-trash"></i> Eliminar
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
