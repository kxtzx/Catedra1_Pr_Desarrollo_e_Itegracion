@model SistemaMantencion.Models.Mantencione

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Mantencione</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <div class="form-group">
                <label asp-for="VehiculoId" class="control-label"></label>
                <select asp-for="VehiculoId" class="form-control" asp-items="ViewBag.VehiculoId"></select>
                <span asp-validation-for="VehiculoId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="FechaMantencion" class="control-label"></label>
                <input asp-for="FechaMantencion" class="form-control" />
                <span asp-validation-for="FechaMantencion" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="RutMecanico" class="control-label"></label>
                <input asp-for="RutMecanico" class="form-control" />
                <span asp-validation-for="RutMecanico" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="HorasTrabajadas" class="control-label"></label>
                <input asp-for="HorasTrabajadas" class="form-control" />
                <span asp-validation-for="HorasTrabajadas" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
